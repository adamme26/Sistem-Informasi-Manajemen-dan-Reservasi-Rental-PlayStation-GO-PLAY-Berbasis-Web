flowchart TD
    %% Styling
    classDef actor fill:#f9f9f9,stroke:#333,stroke-width:2px;
    classDef view fill:#e1f5fe,stroke:#0288d1,stroke-width:2px;
    classDef controller fill:#fff3e0,stroke:#f57c00,stroke-width:2px;
    classDef model fill:#e8f5e9,stroke:#388e3c,stroke-width:2px;

    %% Aktor
    Owner(["👨‍💼 Owner"]) ::: actor
    Member(["👤 Member"]) ::: actor

    %% Bagian View
    subgraph View ["🖼️ VIEW (Frontend: Blade + Vite)"]
        direction TB
        V_Login["Halaman Login & Utama"] ::: view
        V_DashboardO["Dashboard Owner\n(Monitoring, Laporan)"] ::: view
        V_DashboardM["Dashboard Member\n(Booking Online)"] ::: view
    end

    %% Bagian Controller
    subgraph Controller ["⚙️ CONTROLLER (Backend: Laravel 12)"]
        direction TB
        C_Route{"Routing / Web.php"} ::: controller
        C_Auth["AuthController"] ::: controller
        C_Booking["BookingController"] ::: controller
        C_Console["ConsoleController"] ::: controller
        C_Report["ReportController"] ::: controller
    end

    %% Bagian Model
    subgraph Model ["🗄️ MODEL (Database: SQLite)"]
        direction TB
        M_User[("User (Owner & Member)")] ::: model
        M_Console[("Console (PS4 & PS5)")] ::: model
        M_Booking[("Booking (Reservasi)")] ::: model
        M_Transaction[("Transaction (Pembayaran)")] ::: model
    end

    %% Interaksi Aktor dengan View
    Owner -->|Interaksi| V_Login
    Owner -->|Mengelola| V_DashboardO
    Member -->|Interaksi| V_Login
    Member -->|Booking| V_DashboardM

    %% Interaksi View dengan Controller (Request/Response)
    V_Login <-->|HTTP Request / Response| C_Route
    V_DashboardO <-->|HTTP Request / Response| C_Route
    V_DashboardM <-->|HTTP Request / Response| C_Route

    %% Routing ke Controller spesifik
    C_Route --> C_Auth
    C_Route --> C_Booking
    C_Route --> C_Console
    C_Route --> C_Report

    %% Interaksi Controller dengan Model (CRUD Data)
    C_Auth <-->|Validasi & Sesi| M_User
    C_Booking <-->|Cek Jadwal & Simpan| M_Booking
    C_Booking <-->|Cek Status Unit| M_Console
    C_Console <-->|Kelola Unit| M_Console
    C_Report <-->|Tarik Data Selesai| M_Transaction
    C_Report <-->|Tarik Data Booking| M_Booking
